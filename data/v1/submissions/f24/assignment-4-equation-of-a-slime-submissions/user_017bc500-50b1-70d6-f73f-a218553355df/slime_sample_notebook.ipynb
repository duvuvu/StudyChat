  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 2. Splitting the dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 37,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Take the pandas dataset and split it into our features (X) and label (y)\n",
    "x = data.iloc[:,[0,1]]\n",
    "y = data.iloc[:, [2]]\n",
    "# Use sklearn to split the features and labels into a training/test set. (90% train, 10% test)\n",
    "xtrain, xtest, ytrain, ytest = train_test_split(x,y,test_size=.1, train_size=.9, random_state=42)"
   ]
