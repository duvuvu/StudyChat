   "source": [
    "# Use the cross_val_score function to repeat your experiment across many shuffles of the data\n",
    "cross_val_scores = cross_val_score(model, X, y, cv=10, scoring='r2')\n",
    "print(\"Cross-validation R^2 scores for each fold:\", cross_val_scores)\n",
    "print(\"Mean R^2 score from cross-validation:\", cross_val_scores.mean())\n",
    "print(\"Standard deviation of R^2 scores:\", cross_val_scores.std())\n",
    "# Report on their finding and their significance\n",
