   ],
   "source": [
    "# Use sklearn to train a model on the training set\n",
    "model = LinearRegression()\n",
    "model.fit(X_train, y_train)\n",
    "# Create a sample datapoint and predict the output of that sample with the trained model\n",
    "sample_datapoint = [[400, 200]]\n",
    "predicted_output = model.predict(sample_datapoint)\n",
    "print(\"Predicted size for the sample datapoint (KCl=400, Temperature=200):\", predicted_output[0])\n",
    "# Report on the score for that model, in your own words (markdown, not code) explain what the score means\n",
    "score = model.score(X_train, y_train)\n",
    "print(\"Model R^2 score on the training set:\", score)\n",
    "## Model R² Score Explanation\n",
    "#The R squared score of 0.861 incidicates that about 86.1% of the variablilty in slime size can be explained by the chnaging concentrations of KCL and temperature.\n",
    "\n",
    "# Extract the coefficents and intercept from the model and write an equation for your h(x) using LaTex\n",
    "coefficients = model.coef_ \n",
    "intercept = model.intercept_\n",
    "equation = f\"h(x) = {intercept:.4f} + ({coefficients[0]:.4f} * KCl) + ({coefficients[1]:.4f} * Temperature)\"\n",
    "print(\"The equation of the linear model h(x) is:\")\n",
    "print(equation)"
   ]
