  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Part 5. Using Polynomial Regression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 13,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Mean Squared Error of Polynomial Regression: 1.4693515832582168e-08\n",
      "R^2 Score of Polynomial Regression: 1.0\n",
      "\n",
      "The equation of the polynomial regression model h(x) is:\n",
      "h(x) = 0.0000 + (-0.0000 * x^1) + (12.0000 * x^2) + (0.0286 * x^3) + (2.0000 * x^4) + (0.0000 * x^5)\n"
     ]
    }
   ],
   "source": [
    "# Using the PolynomialFeatures library perform another regression on an augmented dataset of degree 2\n",
    "degree = 2\n",
    "poly = PolynomialFeatures(degree=degree)\n",
    "\n",
    "# Transform the features\n",
    "X_poly = poly.fit_transform(X)\n",
    "\n",
    "# Split the dataset into training and testing sets again\n",
    "X_train_poly, X_test_poly, y_train_poly, y_test_poly = train_test_split(X_poly, y, test_size=0.1, random_state=42)\n",
    "\n",
    "# Create a Linear Regression model\n",
    "model_poly = LinearRegression()\n",
    "\n",
    "# Train the polynomial regression model on the training set\n",
    "model_poly.fit(X_train_poly, y_train_poly)\n",
    "\n",
    "# Make predictions on the test set\n",
    "y_pred_poly = model_poly.predict(X_test_poly)\n",
    "\n",
    "# Calculate metrics\n",
    "mse = mean_squared_error(y_test_poly, y_pred_poly)  \n",
    "r2 = r2_score(y_test_poly, y_pred_poly)              # R^2 Score\n",
    "\n",
    "# Extract coefficients and intercept\n",
    "coefficients_poly = model_poly.coef_\n",
    "intercept_poly = model_poly.intercept_\n",
    "\n",
    "# Output the results\n",
    "print(\"Mean Squared Error of Polynomial Regression:\", mse)\n",
    "print(\"R^2 Score of Polynomial Regression:\", r2)\n",
    "\n",
    "# Write the polynomial equation using LaTeX format\n",
    "equation_poly = \"h(x) = \" + f\"{intercept_poly:.4f} + \" \n",
    "terms = []\n",
    "for i in range(1, len(coefficients_poly)):\n",
    "    term = f\"({coefficients_poly[i]:.4f} * x^{i})\"\n",
    "    terms.append(term)\n",
    "\n",
    "equation_poly += \" + \".join(terms)\n",
    "\n",
    "\n",
    "# Report on the metrics and output the resultant equation as you did in Part 3.\n",
    "#it give an analysis on more than the linear relationship for the growth of the slime\n",
    "print(\"\\nThe equation of the polynomial regression model h(x) is:\")\n",
    "print(equation_poly)\n"
   ]
  }
