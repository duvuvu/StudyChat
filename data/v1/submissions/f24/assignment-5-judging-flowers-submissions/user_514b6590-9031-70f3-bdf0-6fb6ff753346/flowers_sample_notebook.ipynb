    "# i. Use sklearn to train a Neural Network (MLP Classifier) on the training set\n",
    "neural = MLPClassifier(hidden_layer_sizes=(100,), max_iter=200, learning_rate_init=0.001)\n",
    "neural.fit(x_train, y_train)\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "nProb = neural.predict_proba(sampleData)\n",
    "print(f'Prediction Probabilities (Setosa, Versicolour, Virginica): {nProb}')\n",
    "# iii. Report on the score for the Neural Network, what does the score measure?\n",
    "nPred = neural.predict(x_test)\n",
    "nAcc = accuracy_score(y_test, nPred)\n",
    "print(f'Accuracy Score: {nAcc}')\n",
    "# iv: Experiment with different options for the neural network, report on your best configuration\n",
    "# i. Use sklearn to train a Neural Network (MLP Classifier) on the training set\n",
    "neural2 = MLPClassifier(hidden_layer_sizes=(5,5,5), max_iter=200, learning_rate_init=0.001)\n",
    "neural2.fit(x_train, y_train)\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "n2Prob = neural2.predict_proba(sampleData)\n",
    "print(f'Prediction Probabilities (Setosa, Versicolour, Virginica): {n2Prob}')\n",
    "# iii. Report on the score for the Neural Network, what does the score measure?\n",
    "n2Pred = neural2.predict(x_test)\n",
    "n2Acc = accuracy_score(y_test, n2Pred)\n",
    "print(f'Accuracy Score: {n2Acc}')\n",
    "neural3 = MLPClassifier(hidden_layer_sizes=(5,5,5), max_iter=600, learning_rate_init=0.01)\n",
    "neural3.fit(x_train, y_train)\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "n3Prob = neural3.predict_proba(sampleData)\n",
    "print(f'Prediction Probabilities (Setosa, Versicolour, Virginica): {n3Prob}')\n",
    "# iii. Report on the score for the Neural Network, what does the score measure?\n",
    "n3Pred = neural3.predict(x_test)\n",
    "n3Acc = accuracy_score(y_test, n3Pred)\n",
    "print(f'Accuracy Score: {n3Acc}')"
   ]
