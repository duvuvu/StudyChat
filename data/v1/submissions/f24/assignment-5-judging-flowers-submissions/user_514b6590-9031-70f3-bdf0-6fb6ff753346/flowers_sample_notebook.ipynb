    "# Load the dataset (load remotely or locally)\n",
    "data = pd.read_csv('iris.csv')\n",
    "# Output the first 15 rows of the data\n",
    "print(data.head(15))\n",
    "# Display a summary of the table information (number of datapoints, etc.)\n",
    "print(data.describe())"
