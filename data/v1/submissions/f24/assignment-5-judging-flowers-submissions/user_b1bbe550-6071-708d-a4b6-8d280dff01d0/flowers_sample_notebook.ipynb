    "# Load the dataset (load remotely or locally)\n",
    "df = pd.read_csv('./iris.csv')\n",
    "# Output the first 15 rows of the data\n",
    "print(df.head(15))\n",
    "# Display a summary of the table information (number of datapoints, etc.)\n",
    "df.info()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "wRMtsJKBaxWu"
   },
   "source": [
    "## About the dataset\n",
    "Explain what the data is in your own words. What are your features and labels? What is the mapping of your labels to the actual classes?\n",
    "\n",
    "The features are the length and width of a sepal and the length and width of the petal. The labels map to the three flower species we're categorizing: setosa, veriscolor, and virginica."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "DhKaIrZKNaHg"
   },
   "source": [
    "# Part 2: Split the dataset into train and test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 10,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "OrgogB62NcOi",
    "outputId": "7bbfb1ea-88ed-4944-ab94-48696b9a71df"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "xTrain check: (135, 4)\n",
      "yTrain check: (135, 1)\n",
      "xTest check: (15, 4)\n",
      "yTest check: (15, 1)\n"
     ]
    }
   ],
   "source": [
    "# Take the dataset and split it into our features (X) and label (y)\n",
    "dfCopy = df.copy()\n",
    "x = dfCopy.drop('species', axis = 1)\n",
    "y = dfCopy.drop(['sepal_length','sepal_width','petal_length','petal_width'], axis = 1)\n",
    "\n",
    "# Use sklearn to split the features and labels into a training/test set. (90% train, 10% test)\n",
    "xTrain, xTest, yTrain, yTest = train_test_split(x, y,  test_size = 0.1)\n",
    "print(f\"xTrain check: {xTrain.shape}\")\n",
    "print(f\"yTrain check: {yTrain.shape}\")\n",
    "print(f\"xTest check: {xTest.shape}\")\n",
    "print(f\"yTest check: {yTest.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "hblF-ei9Ncia"
   },
   "source": [
    "# Part 3: Logistic Regression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "IhFhEN03Nf7o",
    "outputId": "15a94661-020b-4520-b5f3-c34fdfb042f2"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "datapoint:\n",
      "   sepal_length  sepal_width  petal_length  petal_width\n",
      "0           5.4          3.9           1.3          0.4\n",
      "predicted output: setosa\n",
      "\n",
      "Class setosa's probability: 0.98572\n",
      "Class versicolor's probability: 0.01428\n",
      "Class virginica's probability: 0.00000\n",
      "\n",
      "the score of the model is: 1.0\n",
      "\n",
      "params: [[-0.42140685  0.92188033 -2.46683526 -1.05176137]\n",
      " [ 0.49056348 -0.26708457 -0.15292339 -0.95033415]\n",
      " [-0.06915663 -0.65479576  2.61975865  2.00209552]]\n",
      "intercept: [  9.6858067    2.11468461 -11.80049131]\n"
     ]
    }
   ],
   "source": [
    "# i. Use sklearn to train a LogisticRegression model on the training set\n",
    "logRegModel = LogisticRegression()\n",
    "logRegModel.fit(xTrain, yTrain.values.ravel())\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = pd.DataFrame({'sepal_length':[5.4], 'sepal_width':[3.9], 'petal_length':[1.3], 'petal_width':[0.4]})\n",
    "prediction = logRegModel.predict(sample)\n",
    "print(f'datapoint:\\n{sample}\\npredicted output: {prediction[0]}\\n') \n",
    "predictProb = logRegModel.predict_proba(sample)\n",
    "for i, prob in enumerate(predictProb):\n",
    "    for index, label in enumerate(logRegModel.classes_):\n",
    "        print(f\"Class {label}'s probability: {prob[index]:.5f}\")\n",
    "\n",
    "# iii. Report on the score for Logistic regression model, what does the score measure?\n",
    "score = logRegModel.score(xTest, yTest)\n",
    "print(f\"\\nthe score of the model is: {score}\\n\")\n",
    "\n",
    "# iv. Extract the coefficents and intercepts for the boundary line(s)\n",
    "params = logRegModel.coef_\n",
    "intercept = logRegModel.intercept_\n",
    "print(f\"params: {params}\\nintercept: {intercept}\")"
   ]
  },
