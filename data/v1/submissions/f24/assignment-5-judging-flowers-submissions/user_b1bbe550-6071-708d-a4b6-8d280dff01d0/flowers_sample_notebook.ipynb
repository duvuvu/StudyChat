   "source": [
    "# i. Use sklearn to train a Neural Network (MLP Classifier) on the training set\n",
    "nnModel = MLPClassifier(max_iter=600, learning_rate_init=0.01)\n",
    "nnModel.fit(xTrain, yTrain.values.ravel())\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = pd.DataFrame({'sepal_length':[5.4], 'sepal_width':[3.9], 'petal_length':[1.3], 'petal_width':[0.4]})\n",
    "prediction = nnModel.predict(sample)\n",
    "print(f'datapoint:\\n{sample}\\npredicted output: {prediction[0]}\\n') \n",
    "predictProb = nnModel.predict_proba(sample)\n",
    "for i, prob in enumerate(predictProb):\n",
    "    for index, label in enumerate(nnModel.classes_):\n",
    "        print(f\"Class {label}'s probability: {prob[index]:.5f}\")\n",
    "\n",
    "# iii. Report on the score for the Neural Network, what does the score measure?\n",
    "score = nnModel.score(xTest, yTest)\n",
    "print(f\"\\nthe score of the model is: {score}\")\n",
    "\n",
    "# iv: Experiment with different options for the neural network, report on your best configuration"
   ]
