   "source": [
    "# i. Use sklearn to train a Support Vector Classifier on the training set\n",
    "svcModel = SVC(probability = True)\n",
    "svcModel.fit(xTrain, yTrain.values.ravel())\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = pd.DataFrame({'sepal_length':[5.4], 'sepal_width':[3.9], 'petal_length':[1.3], 'petal_width':[0.4]})\n",
    "prediction = svcModel.predict(sample)\n",
    "print(f'datapoint:\\n{sample}\\npredicted output: {prediction}\\n') \n",
    "predictProb = svcModel.predict_proba(sample)\n",
    "for i, prob in enumerate(predictProb):\n",
    "    for index, label in enumerate(svcModel.classes_):\n",
    "        print(f\"Class {label}'s probability: {prob[index]:.5f}\")\n",
    "\n",
    "# iii. Report on the score for the SVM, what does the score measure?\n",
    "score = svcModel.score(xTest, yTest)\n",
    "print(f\"\\nthe score of the model is: {score}\")"
   ]
