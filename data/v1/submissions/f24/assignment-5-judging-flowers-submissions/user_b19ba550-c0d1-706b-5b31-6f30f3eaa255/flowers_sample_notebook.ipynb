    "# Load the dataset (load remotely or locally)\n",
    "df = pd.read_csv(\"iris.csv\")\n",
    "\n",
    "# Output the first 15 rows of the data\n",
    "print(df.head(15))\n",
    "# Display a summary of the table information (number of data points, etc.)\n",
    "df.info()"
   ]
