   ],
   "source": [
    "# 1. Import necessary libraries\n",
    "from sklearn.neural_network import MLPClassifier\n",
    "\n",
    "# 2. Scale the data\n",
    "scaler = StandardScaler()\n",
    "X_train_scaled = scaler.fit_transform(X_train)  # Fit and transform the training data\n",
    "X_test_scaled = scaler.transform(X_test)  # Transform the test data\n",
    "\n",
    "# i. Use sklearn to train a Neural Network (MLP Classifier) on the training set\n",
    "model_mlp = MLPClassifier(max_iter=10000, activation='relu', solver='adam', random_state=42)\n",
    "model_mlp.fit(X_train_scaled, y_train)\n",
    "\n",
    "# ii. For a sample data point, predict the probabilities for each possible class\n",
    "sample_df = pd.DataFrame({'sepal_length': [5.4], 'sepal_width': [3.6], 'petal_length': [1.9], 'petal_width': [0.3]})\n",
    "sample_scaled = scaler.transform(sample_df)\n",
    "probabilities = model_mlp.predict_proba(sample_scaled)\n",
    "\n",
    "class_labels = model_mlp.classes_\n",
    "for prob, label in zip(probabilities[0], class_labels):\n",
    "    print(f\"Probability of class '{label}': {prob:.4f}\")\n",
    "\n",
    "# iii. Report on the score for the Neural Network\n",
    "y_pred = model_mlp.predict(X_test_scaled)  \n",
    "score = accuracy_score(y_test, y_pred)\n",
    "print(\"Accuracy score of the MLP model:\", score)\n",
    "\n",
    "# iv. Experiment with different options for the neural network\n",
    "\n",
    "# Best configuration could be found through hyperparameter tuning\n",
    "# This is an example; you can experiment with more configurations as needed\n",
    "\n",
    "# Trying different configurations\n",
    "best_score = 0\n",
    "best_params = {}\n",
    "\n",
    "# Experimenting with different hidden layer sizes\n",
    "hidden_layer_sizes_options = [(1, ), (5, ), (10,), (50,), (100,), (100, 50), (150, 100), (100, 100, 50)]\n",
    "for layers in hidden_layer_sizes_options:\n",
    "    model = MLPClassifier(max_iter=10000, hidden_layer_sizes=layers, activation='relu', solver='adam', random_state=42)\n",
    "    model.fit(X_train_scaled, y_train)\n",
    "    y_pred = model.predict(X_test_scaled)\n",
    "    score = accuracy_score(y_test, y_pred)\n",
    "    print(f\"Configuration: {layers} - Accuracy: {score:.4f}\")\n",
    "    \n",
    "    # Check for the best score and configuration\n",
    "    if score > best_score:\n",
    "        best_score = score\n",
    "        best_params = layers\n",
    "\n",
    "print(\"\\nBest Configuration:\", best_params)\n",
    "print(\"Best Accuracy Score:\", best_score)\n",
    "print(\"From this experiment, I discovered that for a maximum number of iterations of 10000 the best configuration is (5, ) with 5 hidden layers.\\n Before this the accuracy score doesn't reach 1.0 and this is the least complex model with that score.\")\n"
   ]
