    "# 1. Import necessary libraries\n",
    "from sklearn.svm import SVC\n",
    "\n",
    "# 2. Scale the data\n",
    "scaler = StandardScaler()  # Initialize the scaler\n",
    "X_train_scaled = scaler.fit_transform(X_train)  # Fit and transform the training data\n",
    "X_test_scaled = scaler.transform(X_test)  # Only transform the test data\n",
    "\n",
    "# i. Use sklearn to train a Support Vector Classifier on the training set\n",
    "model_svc = SVC(probability=True)  # Set probability=True to enable predict_proba\n",
    "model_svc.fit(X_train_scaled, y_train)\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample_df = pd.DataFrame({'sepal_length': [5.4], 'sepal_width': [3.6], 'petal_length': [1.9], 'petal_width': [0.3]})\n",
    "sample_scaled = scaler.transform(sample_df)\n",
    "probabilities = model_svc.predict_proba(sample_scaled)\n",
    "class_labels = model_svc.classes_\n",
    "for prob, label in zip(probabilities[0], class_labels):\n",
    "    print(f\"Probability of class '{label}': {prob:.4f}\")\n",
    "\n",
    "# iii. Report on the score for the SVM\n",
    "y_pred = model_svc.predict(X_test_scaled) \n",
    "score = accuracy_score(y_test, y_pred)\n",
    "print(\"Accuracy score of the SVM model:\", score)\n",
    "\n",
    "print(\"The score measures the proportion of correctly predicted sample out of the total amount of samples in the test data. \\nThe SVM model had an accuracy score of 1.0 meaning it predict all of the balls correctly.\")"
   ]
