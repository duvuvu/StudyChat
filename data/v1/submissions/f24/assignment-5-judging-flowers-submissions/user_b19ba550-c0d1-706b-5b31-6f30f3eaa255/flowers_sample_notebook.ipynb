    "sample_scaled = scaler.transform(sample_df)\n",
    "probabilities = model_knn.predict_proba(sample_scaled)\n",
    "class_labels = model_knn.classes_\n",
    "for prob, label in zip(probabilities[0], class_labels):\n",
    "    print(f\"Probability of class '{label}': {prob:.4f}\")\n",
    "\n",
    "# iii. Report on the score for kNN\n",
    "y_pred = model_knn.predict(X_test_scaled) \n",
    "score = accuracy_score(y_test, y_pred)\n",
    "print(\"Accuracy score of the KNN model:\", score)\n",
    "\n",
    "# Explanation of what the score measures\n",
    "print(\"The score measures the accuracy, which is the proportion of correctly predicted samples out of the total samples in the test set.\")\n"
