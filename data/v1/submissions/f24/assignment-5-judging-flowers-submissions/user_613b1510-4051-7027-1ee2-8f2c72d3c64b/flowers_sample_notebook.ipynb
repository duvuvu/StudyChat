   ],
   "source": [
    "# Load the dataset (load remotely or locally)\n",
    "data = pd.read_csv(\"iris.csv\")\n",
    "\n",
    "\n",
    "# Output the first 15 rows of the data\n",
    "# Display a summary of the table information (number of datapoints, etc.)\n",
    "print (\"First 15 Rows of Dataset:\")\n",
    "print (data.head(15))\n",
    "print (\"\\nMean:\")\n",
    "print(data.groupby(\"species\").mean())\n",
    "print (\"\\nMax:\")\n",
    "print(data.groupby(\"species\").max())\n",
    "print (\"\\nMin:\")\n",
    "print(data.groupby(\"species\").min())\n",
    "data[\"species\"] = data[\"species\"].map({\"setosa\": 0, \"versicolor\": 5, \"virginica\": 10})\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "wRMtsJKBaxWu"
   },
   "source": [
    "## About the dataset\n",
    "Explain what the data is in your own words. What are your features and labels? What is the mapping of your labels to the actual classes?"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Answer:\n",
    "    The features of this data are the lengths and widths of both sepals and petals from 3 different flower species. The labels are the different species of Iris flowers. The mapping that I am using for this analysis is setosa = 0, versicolor = 5, virginica = 10. That means that when it predicts the species of flower of a given data point it will hopefully return a value close to one of these three numbers."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "DhKaIrZKNaHg"
   },
   "source": [
    "# Part 2: Split the dataset into train and test"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 46,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "OrgogB62NcOi",
    "outputId": "7bbfb1ea-88ed-4944-ab94-48696b9a71df"
   },
   "outputs": [],
   "source": [
    "# Take the dataset and split it into our features (X) and label (y)\n",
    "x = data[[ \"sepal_length\", \"sepal_width\", \"petal_length\", \"petal_width\"]]\n",
    "y = data[\"species\"]\n",
    "\n",
    "\n",
    "# Use sklearn to split the features and labels into a training/test set. (90% train, 10% test)\n",
    "x_train, x_test, y_train, y_test = ms.train_test_split(x,y, test_size = 0.1, train_size = 0.9, random_state=5)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "hblF-ei9Ncia"
   },
   "source": [
    "# Part 3: Logistic Regression"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 47,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "IhFhEN03Nf7o",
    "outputId": "15a94661-020b-4520-b5f3-c34fdfb042f2"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Prediction for [5, 3.4, 1.5, 0.25] returns: \n",
      "\tSetosa = 97.553 %\n",
      "\tVersicolor = 2.447 %\n",
      "\tVirginica = 0.0 % \n",
      "\n",
      "Prediction for [6, 2.7, 4.3, 1.3] returns: \n",
      "\tSetosa = 0.88 %\n",
      "\tVersicolor = 91.803 %\n",
      "\tVirginica = 7.317 % \n",
      "\n",
      "Prediction for [6.6, 3, 5.5, 2] returns: \n",
      "\tSetosa = 0.004 %\n",
      "\tVersicolor = 8.183 %\n",
      "\tVirginica = 91.812 % \n",
      "\n",
      "Score of Logistic model: 0.93333 \n",
      "\n",
      "Boundary Lines: \n",
      "\n",
      "\tLine #0: 9.625 +  (-0.445x₁) +  (0.906x₂) +  (-2.397x₃) +  (-1.038x₄) \n",
      "\n",
      "\tLine #1: 1.694 +  (0.671x₁) +  (-0.475x₂) +  (-0.149x₃) +  (-1.079x₄) \n",
      "\n",
      "\tLine #2: -11.319 +  (-0.226x₁) +  (-0.431x₂) +  (2.546x₃) +  (2.118x₄) \n",
      "\n"
     ]
    }
   ],
   "source": [
    "# i. Use sklearn to train a LogisticRegression model on the training set\n",
    "model = lm.LogisticRegression()\n",
    "reg = model.fit(x_train.values, y_train)\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = [[5, 3.4, 1.5, .25] ,[6, 2.7, 4.3, 1.3], [6.6, 3, 5.5, 2]]  #mean values for all three flower species\n",
    "results = reg.predict_proba(sample)\n",
    "for x in range(3):\n",
    "    print (f\"Prediction for {sample[x]} returns: \")\n",
    "    print (f\"\\tSetosa = {round(results[x][0] * 100, 3)} %\")\n",
    "    print (f\"\\tVersicolor = {round(results[x][1] * 100, 3)} %\")\n",
    "    print (f\"\\tVirginica = {round(results[x][2] * 100, 3)} % \\n\")\n",
    "\n",
    "# iii. Report on the score for Logistic regression model, what does the score measure?\n",
    "print(f\"Score of Logistic model: {round(reg.score(x_test.values, y_test), 5)} \\n\")\n",
    "\n",
    "\n",
    "# iv. Extract the coefficents and intercepts for the boundary line(s)\n",
    "\n",
    "print (\"Boundary Lines: \\n\")\n",
    "for i in range(3):\n",
    "    print(f\"\\tLine #{i}: {round(reg.intercept_[i], 3)} + \",\n",
    "          f\"({round(reg.coef_[i][0], 3)}x₁) + \",\n",
    "          f\"({round(reg.coef_[i][1], 3)}x₂) + \",\n",
    "          f\"({round(reg.coef_[i][2], 3)}x₃) + \",\n",
    "          f\"({round(reg.coef_[i][3], 3)}x₄) \\n\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "BDUpXQN4Nilk"
   },
   "source": [
    "# Part 4: Support Vector Machine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 48,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "U__zukpdNqiQ",
    "outputId": "5cd81a50-9137-4f36-842e-0687e9bc7c45"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Prediction for [5, 3.4, 1.5, 0.25] returns: \n",
      "   Setosa = 97.022 %\n",
      "   Versicolor = 2.001 %\n",
      "   Virginica = 0.977 % \n",
      "\n",
      "Prediction for [6, 2.7, 4.3, 1.3] returns: \n",
      "   Setosa = 0.566 %\n",
      "   Versicolor = 97.353 %\n",
      "   Virginica = 2.08 % \n",
      "\n",
      "Prediction for [6.6, 3, 5.5, 2] returns: \n",
      "   Setosa = 0.816 %\n",
      "   Versicolor = 1.396 %\n",
      "   Virginica = 97.789 % \n",
      "\n",
      "Score of SVM model: 0.93333 \n",
      "\n"
     ]
    }
   ],
   "source": [
    "# i. Use sklearn to train a Support Vector Classifier on the training set\n",
    "svmmodel = svm.SVC(probability=True)\n",
    "svmreg = svmmodel.fit(x_train.values, y_train)\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = [[5, 3.4, 1.5, .25] ,[6, 2.7, 4.3, 1.3], [6.6, 3, 5.5, 2]]  #mean values for all three flower species\n",
    "results = svmreg.predict_proba(sample)\n",
    "for x in range(3):\n",
    "    print (f\"Prediction for {sample[x]} returns: \")\n",
    "    print (f\"   Setosa = {round(results[x][0] * 100, 3)} %\")\n",
    "    print (f\"   Versicolor = {round(results[x][1] * 100, 3)} %\")\n",
    "    print (f\"   Virginica = {round(results[x][2] * 100, 3)} % \\n\")\n",
    "\n",
    "\n",
    "# iii. Report on the score for the SVM, what does the score measure?\n",
    "print(f\"Score of SVM model: {round(svmreg.score(x_test.values, y_test),5)} \\n\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "ULoL7mMBNrlS"
   },
   "source": [
    "# Part 5: Neural Network"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 49,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "CKKmODVrN9lQ",
    "outputId": "dced24f7-c6bd-45fb-c68f-87548e9228dc"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Prediction for [5, 3.4, 1.5, 0.25] returns: \n",
      "\tSetosa = 99.713 %\n",
      "\tVersicolor = 0.287 %\n",
      "\tVirginica = 0.0 % \n",
      "\n",
      "Prediction for [6, 2.7, 4.3, 1.3] returns: \n",
      "\tSetosa = 0.235 %\n",
      "\tVersicolor = 97.89 %\n",
      "\tVirginica = 1.874 % \n",
      "\n",
      "Prediction for [6.6, 3, 5.5, 2] returns: \n",
      "\tSetosa = 0.0 %\n",
      "\tVersicolor = 2.388 %\n",
      "\tVirginica = 97.612 % \n",
      "\n",
      "Score of NN model: 1.0 \n",
      "\n"
     ]
    }
   ],
   "source": [
    "# i. Use sklearn to train a Neural Network (MLP Classifier) on the training set\n",
    "nnmodel = nn.MLPClassifier(alpha= 0.1, hidden_layer_sizes=(5,6), max_iter=10000, random_state=3)\n",
    "nnreg = nnmodel.fit(x_train.values, y_train)\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = [[5, 3.4, 1.5, .25] ,[6, 2.7, 4.3, 1.3], [6.6, 3, 5.5, 2]]  #mean values for all three flower species\n",
    "results = nnreg.predict_proba(sample)\n",
    "for x in range(3):\n",
    "    print (f\"Prediction for {sample[x]} returns: \")\n",
    "    print (f\"\\tSetosa = {round(results[x][0] * 100, 3)} %\")\n",
    "    print (f\"\\tVersicolor = {round(results[x][1] * 100, 3)} %\")\n",
    "    print (f\"\\tVirginica = {round(results[x][2] * 100, 3)} % \\n\")\n",
    "\n",
    "# iii. Report on the score for the Neural Network, what does the score measure?\n",
    "print(f\"Score of NN model: {round(nnreg.score(x_test.values, y_test),5)} \\n\")\n",
    "\n",
    "# iv: Experiment with different options for the neural network, report on your best configuration"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "Answer:\n",
    "    What I found from playing around with the parameters on the Neural Network is that if the first layer of the network has less than 4 nodes, the accuracy of the model drops drastically. This also happens when you drop the second layer below 4 but it is seems to just has more trouble distiguishing between the two flowers with similar features. I have found that having 5 nodes in the first layer and 6 nodes in the second is sufficient for a high accuracy model. i also played around with the alpha value of the model but it seemed to have little affect on the accuracy and only affected the number of iterations it takes for the algorithm to converge. I kept it at a value of 0.1."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "id": "_bi5tDwHmC28"
   },
   "source": [
    "# Part 6: K-Nearest Neighbors"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 50,
   "metadata": {
    "colab": {
     "base_uri": "https://localhost:8080/"
    },
    "id": "qCFlfJy2mCg6",
    "outputId": "e71bf88c-6418-4b7f-e289-4acf743c16cc"
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Prediction for [5, 3.4, 1.5, 0.25] returns: \n",
      "\tSetosa = 100.0 %\n",
      "\tVersicolor = 0.0 %\n",
      "\tVirginica = 0.0 % \n",
      "\n",
      "Prediction for [6, 2.7, 4.3, 1.3] returns: \n",
      "\tSetosa = 0.0 %\n",
      "\tVersicolor = 100.0 %\n",
      "\tVirginica = 0.0 % \n",
      "\n",
      "Prediction for [6.6, 3, 5.5, 2] returns: \n",
      "\tSetosa = 0.0 %\n",
      "\tVersicolor = 0.0 %\n",
      "\tVirginica = 100.0 % \n",
      "\n",
      "Score of KNN model: 0.93333 \n",
      "\n"
     ]
    }
   ],
   "source": [
    "# i. Use sklearn to 'train' a k-Neighbors Classifier\n",
    "# Note: KNN is a nonparametric model and technically doesn't require training\n",
    "# fit will essentially load the data into the model see link below for more information\n",
    "# https://stats.stackexchange.com/questions/349842/why-do-we-need-to-fit-a-k-nearest-neighbors-classifier\n",
    "knnmodel = knn.KNeighborsClassifier(n_neighbors=10)\n",
    "knnreg = knnmodel.fit(x_train.values, y_train)\n",
    "\n",
    "# ii. For a sample datapoint, predict the probabilities for each possible class\n",
    "sample = [[5, 3.4, 1.5, .25] ,[6, 2.7, 4.3, 1.3], [6.6, 3, 5.5, 2]]  #mean values for all three flower species\n",
    "results = knnreg.predict_proba(sample)\n",
    "for x in range(3):\n",
    "    print (f\"Prediction for {sample[x]} returns: \")\n",
    "    print (f\"\\tSetosa = {round(results[x][0] * 100, 3)} %\")\n",
    "    print (f\"\\tVersicolor = {round(results[x][1] * 100, 3)} %\")\n",
    "    print (f\"\\tVirginica = {round(results[x][2] * 100, 3)} % \\n\")\n",
    "\n",
    "# iii. Report on the score for kNN, what does the score measure?\n",
    "print(f\"Score of KNN model: {round(knnreg.score(x_test.values, y_test),5)} \\n\")"
   ]
  },
  {
